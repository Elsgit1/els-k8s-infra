{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TerraformStateBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::els-k8s-infra-tfstate-466798855028-us-west-1",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "els-k8s-infra/terraform.tfstate",
            "els-k8s-infra/terraform.tfstate.tflock"
          ]
        }
      }
    },
    {
      "Sid": "TerraformStateObjectAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::els-k8s-infra-tfstate-466798855028-us-west-1/els-k8s-infra/terraform.tfstate"
    },
    {
      "Sid": "TerraformStateLockFileAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::els-k8s-infra-tfstate-466798855028-us-west-1/els-k8s-infra/terraform.tfstate.tflock"
    },
    {
      "Sid": "TerraformAwsReadIdentity",
      "Effect": "Allow",
      "Action": "sts:GetCallerIdentity",
      "Resource": "*"
    },
    {
      "Sid": "TerraformEKSInfrastructure",
      "Effect": "Allow",
      "Action": [
        "ec2:*",
        "eks:*",
        "iam:*",
        "kms:*",
        "logs:*",
        "events:*",
        "sqs:*",
        "sns:*",
        "ssm:GetParameter",
        "pricing:GetProducts"
      ],
      "Resource": "*"
    }
  ]
}
